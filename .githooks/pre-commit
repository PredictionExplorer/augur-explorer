#!/usr/bin/env bash
# augur-explorer managed coverage hook
set -euo pipefail

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

status=$(go run ./cmd/covergate -policy coverage/policy.json -commit-status)
case "$status" in
	deferred\ *)
		echo "coverage commit gate: deferred until handwritten internal coverage reaches 90%"
		exit 0
		;;
	enabled\ *)
		# CI and the versioned ratchets use the race-enabled integration
		# profile; the local commit gate must measure the same executable set.
		export COVERAGE_RACE=1
		exec "$repo_root/scripts/coverage-gate.sh"
		;;
	*)
		echo "coverage commit gate: invalid policy status: $status" >&2
		exit 2
		;;
esac
