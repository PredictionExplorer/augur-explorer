# Backend Configuration
PORT=8000
HOST=127.0.0.1
DATA_DIR=./data
LOG_LEVEL=INFO

# Knowledge base (generated text files — outside faq-bot code tree)
KNOWLEDGE_BASE=/home/niko/eth/dev/ai-faq-kb

# Optional: external directory with deployment-*.txt files (merged at generate time)
# DEPLOYMENT_FACTS_DIR=/home/niko/eth/tests/deployment-works

# Monorepo paths
CURSOR_VREF_PATH=/home/niko/eth/dev/b/cursor-vref

# CORS — add your nginx test vhost origin when using the test UI
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000

# Haystack
INCLUDE_CODE_FALLBACK=true

# Session storage (idle timeout before context expires)
SESSION_TTL_SECONDS=3600

# Per-session prompt/response logs (one file per session: {session_id}-{date}.log)
FAQ_BOT_LOG_DIR=/home/niko/ae_logs/ai-faq-bot

# Codex MCP — synthesis only via jailed codex-nsjail (no filesystem/shell MCP tools).
# The backend assembles the full prompt; Codex returns text via codex / codex-reply only.
# Do not add [mcp_servers] entries in /home/aijail/.codex/config.toml beyond Codex defaults.
CODEX_MCP_COMMAND=/usr/local/bin/codex-nsjail
CODEX_MCP_ARGS=mcp-server
# cwd passed to codex tool args (inside nsjail)
CODEX_MCP_CWD=/home/aijail
# cwd for spawning codex-nsjail — must be readable by the FAQ bot OS user (not /home/aijail)
# CODEX_MCP_SPAWN_CWD=/path/to/faq-bot/backend
CODEX_MCP_SANDBOX=read-only
CODEX_MCP_APPROVAL_POLICY=never
# CODEX_MCP_MODEL=gpt-5.4

# Live on-chain reads (cginfo) for current bid price, round status, etc.
# RPC_URL falls back to NEXT_PUBLIC_RPC_URL from facts/network-environment.json if unset.
RPC_URL=https://a1.cosmicsignature.com:38546
CGINFO_PATH=/home/niko/eth/dev/b/cursor-vref/rwcg/etl/cosmicgame/scripts/cginfo
# COSMIC_GAME_ADDR=0x6a714Ae7B5b6eA520F6BCA23d2E609C4Fd5863F2
CGINFO_TIMEOUT_SECONDS=45

# Live indexed data from Cosmic Game REST API (donations, bid counts, round stats)
# Falls back to NEXT_PUBLIC_API_URL from facts/network-environment.json if unset.
FAQ_BOT_API_URL=https://a1.cosmicsignature.com/api/cosmicgame/
FAQ_BOT_API_TIMEOUT_SECONDS=20
