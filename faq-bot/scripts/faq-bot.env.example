# Copy to ~/configs/faq-bot.env — single config file for the FAQ bot on cosmic1.
# Used by: setup-venv.sh, generate-knowledge.sh, reindex-knowledge.sh, start-backend.sh

# --- Required: paths ---
export KNOWLEDGE_BASE=/home/cgprod/ai-faq-kb
export FAQ_BOT_VENV=/home/cgprod/ai-faq-venv
export FAQ_BOT_LOG_DIR=/home/cgprod/ae_logs/ai-faq-bot

# Monorepo root (for KB facts / optional code fallback paths)
export CURSOR_VREF_PATH=/home/cgprod/backend/rwcg

# --- Knowledge generation (generate-knowledge.sh) ---
# Addresses and network env come from repo seeds under backend/knowledge/deployments/.
# Do NOT set DEPLOYMENT_FACTS_DIR unless FAQ_BOT_ALLOW_EXTERNAL_DEPLOYMENT=1 (breaks parity).
# export FAQ_BOT_SKIP_REPO_SYNC=1

# --- HTTP server (start-backend.sh → aifaq-bot.py) ---
export HOST=69.10.55.2
export PORT=7001
export LOG_LEVEL=INFO

# CORS: add your site origin if the browser calls this host directly
# export CORS_ORIGINS=https://app.cosmicsignature.com,http://127.0.0.1:7001

# --- Live Cosmic Game REST API (round stats, stakers, champions) ---
export FAQ_BOT_API_URL="http://a1.cosmicsignature.com:2121/api/cosmicgame/"
export FAQ_BOT_API_TIMEOUT_SECONDS=20

# --- Live on-chain reads via cginfo (bid prices, round timer, contract balance) ---
# Game proxy address defaults from KNOWLEDGE_BASE/facts/deployed-addresses.json
# (repo seed backend/knowledge/deployments/arbitrum-mainnet.txt). Re-run generate-knowledge
# after pulling faq-bot — do not maintain a separate address list per host.
# Optional runtime override only:
# export COSMIC_GAME_ADDR=0x6a714Ae7B5b6eA520F6BCA23d2E609C4Fd5863F2
# Build once:
#   cd $CURSOR_VREF_PATH/etl/cosmicgame/scripts && go build -o cginfo cginfo.go
export RPC_URL=http://a1.cosmicsignature.com:38545
export CGINFO_PATH=/home/cgprod/backend/rwcg/etl/cosmicgame/scripts/cginfo
export CGINFO_TIMEOUT_SECONDS=45

# --- Codex MCP (jailed synthesis — required for /api/query) ---
# Production on cosmic1: passwordless sudo runs this script as root (setuid nsjail does not stick).
#
# One-time (root):
#   mkdir -p /var/lib/nsjail-root && chown root:root /var/lib/nsjail-root && chmod 700 /var/lib/nsjail-root
#   mkdir -p /var/lib/nsjail-aijail && chown aijail:aijail /var/lib/nsjail-aijail && chmod 700 /var/lib/nsjail-aijail
#   cp scripts/codex-nsjail.example /usr/local/bin/codex-nsjail && chmod 755 /usr/local/bin/codex-nsjail
#   echo 'cgprod ALL=(root) NOPASSWD: /usr/local/bin/codex-nsjail mcp-server' >/etc/sudoers.d/faq-bot-codex
#   chmod 440 /etc/sudoers.d/faq-bot-codex && visudo -c
#
export CODEX_MCP_COMMAND=sudo
export CODEX_MCP_ARGS="-n /usr/local/bin/codex-nsjail mcp-server"
export CODEX_MCP_CWD=/home/aijail
# OS user (cgprod) cannot chdir into /home/aijail — spawn wrapper from backend dir instead:
export CODEX_MCP_SPAWN_CWD=/home/cgprod/backend/rwcg/faq-bot/backend
export CODEX_MCP_SANDBOX=read-only
export CODEX_MCP_APPROVAL_POLICY=never

# --- Haystack (optional) ---
# export INCLUDE_CODE_FALLBACK=false
# export SESSION_TTL_SECONDS=3600

# --- Knowledge generation only (generate-knowledge.sh) ---
# export FAQ_BOT_SKIP_REPO_SYNC=1
