# RWCG backend — environment reference.
# Copy to .env (compose) or /etc/rwcg/<service>.env (systemd) and fill in values.
# Never commit real credentials.

# --- PostgreSQL (all services) -----------------------------------------------
PGSQL_USERNAME=rwcg
PGSQL_PASSWORD=change-me
PGSQL_DATABASE=rwcg
# host:port for TCP; leave empty to use the local Unix socket (peer auth)
PGSQL_HOST=localhost:5432

# --- Chain access (apiserver, cg-etl, rw-etl, notibot, CLIs) ------------------
RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# --- API server ---------------------------------------------------------------
HTTP_PORT=8080
# Private metrics/pprof listener (Prometheus scrapes this; never expose publicly).
# cg-etl and rw-etl honor it too — give every process its own port
# (e.g. apiserver 9090, cg-etl 9091, rw-etl 9092).
#METRICS_ADDR=127.0.0.1:9090
# TLS: primary bind address (e.g. :443) enables the HTTPS listener
#HTTPS_HOSTNAME=
#HTTPS_EXTRA_LISTEN_ADDR=
#TLS_CERT_FILE=
#TLS_KEY_FILE=
#TLS_CERT_FILE_2=
#TLS_KEY_FILE_2=
# Route groups (all default to enabled)
#ENABLE_ROUTES_COSMICGAME=true
#ENABLE_ROUTES_RANDOMWALK=true
#ENABLE_ROUTES_FAQ=true
# Shared secret required by mutating endpoints (bid moderation, ranking admin).
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=change-me
#RANKING_ADMIN_KEY=
#RANKING_VOTE_CHAIN_IDS=42161
#RANDOMWALK_EXPLORE_MAX_TOKEN_ID=

# --- NFT asset serving (apiserver) --------------------------------------------
# Directory containing randomwalk/ and new/cosmicsignature/ asset trees
#NFT_ASSETS_ROOT=/var/lib/rwcg/nft-assets
# Public URL base when assets are served from a CDN / different host
#NFT_ASSETS_PUBLIC_BASE=
#NFT_ASSETS_FLAT_PATHS=0
#STATIC_ABI_DIR=
#WEBSRV_IMAGE_NO_CACHE=0
#WEBSRV_LOG_IMAGE_REQUESTS=0

# --- FAQ bot proxy (apiserver) -------------------------------------------------
#FAQ_BOT_UPSTREAM_URL=http://127.0.0.1:8000

# --- Notification bot (notibot) -------------------------------------------------
#TWITTER_KEYS_FILE=/etc/rwcg/twitter-keys.json
#DISCORD_KEYS_FILE=/etc/rwcg/discord-keys.json

# --- WhatsApp alarms (rwalk-alarm, srvmonitor) ----------------------------------
#WHATSAPP_TOKEN=
#WHATSAPP_PHONE_ID=
#PHONE_LIST=

# --- Artifact generation (imggen-monitor) ---------------------------------------
#IM_REQUEST_URL=
#IM_IMAGE_URL=
#IM_VIDEO_URL=

# --- Operator CLIs (cgctl, rwctl) ------------------------------------------------
# Private key for transaction-signing subcommands (hex, no 0x prefix)
#PKEY_HEX=
#CGAME_ADDR=
#GAS_PRICE_MULTIPLIER=1.0
