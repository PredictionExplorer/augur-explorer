# RWCG backend — environment reference.
# Copy to .env (compose) or /etc/rwcg/<service>.env (systemd) and fill in values.
# Never commit real credentials.
#
# This file is verified against the typed service configurations
# (internal/config) by TestEnvExampleMatchesServiceConfigs: every variable a
# service reads is documented here, and every entry here maps to a known
# configuration field (or the CLI tools listed at the bottom).

# --- PostgreSQL (all services) -----------------------------------------------
# Either one DATABASE_URL (wins when set) ...
#DATABASE_URL=postgres://rwcg:change-me@localhost:5432/rwcg
# ... or the individual settings:
PGSQL_USERNAME=rwcg
PGSQL_PASSWORD=change-me
PGSQL_DATABASE=rwcg
# host:port for TCP; leave empty to use the local Unix socket (peer auth)
PGSQL_HOST=localhost:5432

# --- Chain access (apiserver, cg-etl, rw-etl, notibot, CLIs) ------------------
RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# --- Logging (all services) ----------------------------------------------------
# Services log structured records to stdout; systemd/journald persists them.
#LOG_FORMAT=text
#LOG_LEVEL=info

# --- API server ---------------------------------------------------------------
HTTP_PORT=8080
#METRICS_ADDR=127.0.0.1:9090
#HTTPS_HOSTNAME=
#HTTPS_EXTRA_LISTEN_ADDR=
#TLS_CERT_FILE=
#TLS_KEY_FILE=
#TLS_CERT_FILE_2=
#TLS_KEY_FILE_2=
#ENABLE_ROUTES_COSMICGAME=true
#ENABLE_ROUTES_RANDOMWALK=true
#ENABLE_ROUTES_FAQ=true
ADMIN_API_KEY=change-me
#RANKING_ADMIN_KEY=
#RANKING_VOTE_CHAIN_IDS=42161
#RANDOMWALK_EXPLORE_MAX_TOKEN_ID=3766
# Earliest v1 removal moment (RFC 3339), served as the Sunset header on
# deprecated v1 responses. Leave unset until the ADR-0005 sunset gates are met.
#V1_SUNSET_AT=2027-01-01T00:00:00Z

# --- NFT asset serving (apiserver) --------------------------------------------
#NFT_ASSETS_ROOT=/var/lib/rwcg/nft-assets
#NFT_ASSETS_PUBLIC_BASE=
#NFT_ASSETS_FLAT_PATHS=false
#STATIC_ABI_DIR=
#WEBSRV_IMAGE_NO_CACHE=false
#WEBSRV_LOG_IMAGE_REQUESTS=false

# --- FAQ bot proxy (apiserver) -------------------------------------------------
#AI_BOT_BACKEND_URL=http://127.0.0.1:8000
# Legacy alias for AI_BOT_BACKEND_URL:
#FAQ_BOT_UPSTREAM_URL=

# --- Notification bot (notibot) -------------------------------------------------
# File names are resolved under $HOME/configs/.
#TWITTER_KEYS_FILE=twitter-keys.json
#DISCORD_KEYS_FILE=discord-keys.json

# --- WhatsApp alarms (rwalk-alarm) ----------------------------------------------
#WHATSAPP_TOKEN=
#WHATSAPP_PHONE_ID=
#PHONE_LIST=

# --- Artifact generation (imggen-monitor) ---------------------------------------
#IM_REQUEST_URL=
#IM_IMAGE_URL=
#IM_VIDEO_URL=

# --- Operator CLIs (cgctl, rwctl, opsctl) ---------------------------------------
#PKEY_HEX=
#CGAME_ADDR=
#GAS_PRICE_MULTIPLIER=1.0
# opsctl smoketest target (defaults to http://127.0.0.1:$HTTP_PORT):
#API_BASE=

# --- cgctl autobid bot -----------------------------------------------------------
#MAX_ETH_BID=5.0
#MAX_CST_BID=9.0
#RWALK_MIN_PRICE=0.1
#TIME_BEFORE_PRIZE=15
#CST_BID_ANYWAY=true
#AT_STARTUP_BID_UP_TO_PRICE_LEVEL=

# The srvmonitor TUI reads its own indexed variable families (RPC{n}_URL,
# DB_L1_*_SRV{n}, SSL_CERT{n}_*, ...); see cmd/srvmonitor/README.md.
# API probes must stay off deprecated v1 paths so they do not pollute the D6
# zero-traffic window. Internal readiness + a stable public v2 read:
#SRV1_WEB_API_NAME=cosmic-api
#SRV1_WEB_API_HOST=127.0.0.1
#SRV1_WEB_API_PORT=8080
#SRV1_WEB_API_URI=/readyz
#SRV1_WEB_API_PUBLIC_URL=https://api.example/api/v2/cosmicgame/rounds?limit=1

# Event-watermark monitors accept DB_L1EVT1 through DB_L1EVT6. TABLE and
# COLUMN default to cg_proc_status and last_evt_id when omitted.
#DB_L1EVT1_NAME=cosmic-events
#DB_L1EVT1_HOST=127.0.0.1:5432
#DB_L1EVT1_DBNAME=rwcg
#DB_L1EVT1_USER=rwcg_monitor
#DB_L1EVT1_PASS=change-me
#DB_L1EVT1_TABLE=cg_proc_status
#DB_L1EVT1_COLUMN=last_evt_id
# Repeat the same seven suffixes for slots 2 through 6:
#DB_L1EVT6_NAME=randomwalk-events
#DB_L1EVT6_HOST=127.0.0.1:5432

# The anomaly feed stays backward-compatible with markerless files. New
# loganomaly generations carry a heartbeat and become stale after 1800s by
# default; malformed/non-positive ANOMALY_STALE_SECS fails startup.
#ANOMALY_TITLE=Production WebSrv Anomalies
#ANOMALY_SSH_USER=rwcg
#ANOMALY_SSH_HOST=cosmic1
#ANOMALY_REMOTE_FILE=/var/lib/rwcg/loganomaly/webserver_anomalies.log
#ANOMALY_STALE_SECS=1800
